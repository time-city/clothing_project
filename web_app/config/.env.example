# Cloudinary Configuration File
# 
# Hướng dẫn:
# 1. Tạo tài khoản Cloudinary (miễn phí): https://cloudinary.com/
# 2. Lấy credentials từ Dashboard > Account Details
# 3. Điền các giá trị dưới đây
# 4. Lưu file này (không commit lên GitHub!)

# Phương pháp 1: Sử dụng file này (cách cũ - không khuyên nghị)
# - Copy file này
# - Điền credentials
# - Cập nhật app.py để load file này

# Phương pháp 2: Sử dụng Environment Variables (KHUYÊN NGHỊ)
# export CLOUDINARY_CLOUD_NAME="your_cloud_name"
# export CLOUDINARY_API_KEY="your_api_key"
# export CLOUDINARY_API_SECRET="your_api_secret"

# Phương pháp 3: Tạo .env file
# Tạo file `.env` trong folder web_app:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Sau đó cài: pip install python-dotenv
# Và thêm vào app.py:
# from dotenv import load_dotenv
# load_dotenv()

# ==================== CREDENTIALS ====================

CLOUDINARY_CLOUD_NAME = "your_cloud_name"
CLOUDINARY_API_KEY = "your_api_key"
CLOUDINARY_API_SECRET = "your_api_secret"

# ==================== LẤY CREDENTIALS ====================
#
# Bước 1: Đăng ký Cloudinary
# - Vào: https://cloudinary.com/
# - Click "Sign Up"
# - Xác minh email
#
# Bước 2: Lấy Credentials
# - Đăng nhập Cloudinary Dashboard
# - Tìm "Account Details" phía trên
# - Bạn sẽ thấy:
#   - Cloud Name: xxxxxx
#   - API Key: 123456789
#   - API Secret: abcdefghijklmnop
#
# Bước 3: Điền vào
# - Sao chép từng giá trị vào trên
# - Không để dấu ngoặc kép
#
# Bước 4: Khởi động
# - Chạy: python app.py
# - Upload ảnh & test

# ==================== LỢI ÍCH ====================
#
# ✅ 25GB storage miễn phí
# ✅ 25GB bandwidth/tháng
# ✅ Unlimited uploads
# ✅ On-the-cloud, không cần server storage
# ✅ Fast CDN delivery
# ✅ Tích hợp dễ dàng
